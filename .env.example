# Copia este archivo como .env y completa los valores

# Credenciales Gmail (usa una App Password, no tu contraseña real)
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
REMITENTE=Reportes de Venta <tu_correo@gmail.com>

# SMTP (opcional, por defecto Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Archivos (opcional, relativo a la carpeta del proyecto)
EXCEL_FILE=Prueba_envio_de_mails.xlsx
HTML_FILE=reporte_ventas_vendedor.html

# Meta de ventas individual (sin puntos ni comas)
META=100000
